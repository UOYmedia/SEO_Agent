# Database
DATABASE_URL=sqlite:///./seo_agent.db
# DATABASE_URL=postgresql://user:password@localhost/seo_agent

# Security
SECRET_KEY=change-me-in-production

# Shopify
SHOPIFY_SHOP_DOMAIN=mystore.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxx
SHOPIFY_API_VERSION=2024-01

# WooCommerce (Phase 2)
WC_STORE_URL=https://mystore.com
WC_CONSUMER_KEY=ck_xxxxxxxxxxxx
WC_CONSUMER_SECRET=cs_xxxxxxxxxxxx

# Anthropic (content generation)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx
ANTHROPIC_MODEL=claude-opus-4-7

# Serper (Google Search + PAA)
SERPER_API_KEY=xxxxxxxxxxxx

# OpenAI (required for embeddings + DALL-E image generation)
OPENAI_API_KEY=sk-xxxxxxxxxxxx

# OpenRouter — optional, replaces OpenAI for all text generation (cheaper + more models)
# Get your key at https://openrouter.ai/keys  |  Leave empty to keep using OpenAI
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxx
# Model overrides — leave empty to use smart defaults per agent
# OPENAI_MODEL_FAST=google/gemini-2.0-flash-001    # research, planning, keyword suggester
# OPENAI_MODEL_SMART=anthropic/claude-sonnet-4-5   # copywrite, learning (+ prompt caching)
# OPENAI_MODEL=deepseek/deepseek-r1                # audit

# Cloudinary (image hosting)
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
